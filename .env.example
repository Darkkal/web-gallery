# Where production data lives on the host — fast storage (SSD preferred).
# Contains: database, scraper state (archives, logs, config)
WEBGALLERY_DATA_DIR=./webgallery-data

# Where downloaded media lives on the host — bulk storage (large drive).
# Contains: scraped images/videos, cached avatars
WEBGALLERY_MEDIA_DIR=./webgallery-media
